# ===========================================
# Sky AutoRent Web — Environment Variables
# Скопируй в .env.local для локальной разработки
# или в .env на сервере для Docker
# ===========================================

# --- Site ---
NEXT_PUBLIC_SITE_NAME=Sky AutoRent
NEXT_PUBLIC_LOGO_PATH=/logo-blue.png
NEXT_PUBLIC_LOGO_VERSION=20260616
# Когда появится тёмное лого:
NEXT_PUBLIC_LOGO_DARK_PATH=
NEXT_PUBLIC_ENABLE_DARK_THEME=false

# --- 3D Model (папка public/models в .gitignore) ---
# После npm run optimize:model используй .optimized.glb (~2 MB вместо ~50 MB)
NEXT_PUBLIC_MODEL_3D_PATH=/models/maserati.optimized.glb

# --- Contacts (замени на реальные данные клиента) ---
NEXT_PUBLIC_CONTACT_PHONE=+7 (777) 123-45-67
NEXT_PUBLIC_CONTACT_PHONE_HREF=tel:+77771234567
NEXT_PUBLIC_CONTACT_EMAIL=info@skyautorent.kz
NEXT_PUBLIC_CONTACT_ADDRESS=Алматы, пр. Абая 150
NEXT_PUBLIC_CONTACT_WORKING_HOURS=Ежедневно, 09:00 — 21:00

# --- Social (кликабельные ссылки) ---
NEXT_PUBLIC_SOCIAL_TELEGRAM=https://t.me/sky_autorent_test
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/sky_autorent_test
NEXT_PUBLIC_SOCIAL_WHATSAPP=https://wa.me/77771234567
NEXT_PUBLIC_SOCIAL_TIKTOK=https://tiktok.com/@sky_autorent_test

# --- Social labels (отображаемый текст) ---
NEXT_PUBLIC_SOCIAL_TELEGRAM_LABEL=@sky_autorent_test
NEXT_PUBLIC_SOCIAL_INSTAGRAM_LABEL=@sky_autorent_test
NEXT_PUBLIC_SOCIAL_WHATSAPP_LABEL=+7 (777) 123-45-67
NEXT_PUBLIC_SOCIAL_TIKTOK_LABEL=@sky_autorent_test

# --- Email form (server-side) ---
CONTACT_EMAIL=groozeff@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# --- Docker ---
PORT=3000
NODE_ENV=production
